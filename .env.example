# ── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[your-project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Servicios externos ────────────────────────────────────────────────────────
# NINGUNO. Todo funciona 100% con Supabase:
#
#   Verificación de email (OTP 6 dígitos):
#     → Supabase Auth → signInWithOtp / verifyOtp
#     → Configura plantilla: Supabase Dashboard → Auth → Email Templates
#     → SMTP propio (producción): Project Settings → Auth → SMTP Settings
#
#   Diagnósticos:
#     → Guardados en tamiz_diagnosticos (Supabase DB)
#     → Ops consulta: Supabase Dashboard → Table Editor → tamiz_diagnosticos

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
