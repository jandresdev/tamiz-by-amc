# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[your-project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Resend — email de diagnóstico a ops@amcprincipal.com ─────────────────────
# Obtener en: https://resend.com → API Keys (tier gratis: 3.000 emails/mes)
# Verificar dominio: resend.com → Domains → Add Domain → amcprincipal.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@amcprincipal.com

# ── Verificación OTP ──────────────────────────────────────────────────────────
# Manejado 100% por Supabase Auth. Sin clave adicional.
# Configurar plantilla: Supabase Dashboard → Auth → Email Templates
# SMTP propio (producción): Project Settings → Auth → SMTP Settings

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
