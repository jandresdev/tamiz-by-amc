# Supabase Configuration
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[your-project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Verificación de email (OTP) ─────────────────────────────────────────────
# La verificación de email se hace 100% con Supabase Auth OTP.
# NO se necesita Brevo ni ningún otro servicio de email para la verificación.
#
# Para que lleguen los emails de verificación:
#   1. Supabase Dashboard → Project Settings → Auth → SMTP Settings
#      → Configura tu propio SMTP (SendGrid, Resend, etc.)
#   2. Supabase Dashboard → Auth → Email Templates
#      → Personaliza el asunto y cuerpo del email de "Magic Link / OTP"
#
# Sin SMTP propio, Supabase usa su servidor interno (limitado a 3 emails/hora en free plan).

# ── Diagnóstico a ops ────────────────────────────────────────────────────────
# Web3Forms envía el reporte completo a ops@amcprincipal.com
# Obtener access key en: https://web3forms.com
WEB3FORMS_ACCESS_KEY=your-web3forms-access-key-here

# Application Settings
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
