# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[your-project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Verificación OTP ──────────────────────────────────────────────────────────
# Manejado 100% por Supabase Auth. Sin clave adicional.
# Configurar plantilla: Supabase Dashboard → Auth → Email Templates
# SMTP propio (producción): Project Settings → Auth → SMTP Settings

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# ── Cron (limpieza de archivos expirados) ────────────────────────────────────
# Generar con: openssl rand -base64 32
# Vercel envía este valor como "Authorization: Bearer <CRON_SECRET>" en cada
# invocación programada (ver vercel.json) — debe configurarse en el proyecto Vercel.
CRON_SECRET=your-random-secret-here

# ── SMTP para la Edge Function "send-diagnostic" ─────────────────────────────
# Configurar como Secrets en Supabase Edge Functions, NO como env vars de Next.js:
#   Supabase Dashboard → Edge Functions → send-diagnostic → Secrets
#   O con CLI: supabase secrets set SMTP_HOST=... SMTP_PORT=587 ...
#
# SMTP_HOST=mail.amcprincipal.com        # servidor SMTP de tu proveedor
# SMTP_PORT=587                           # 587 (STARTTLS) o 465 (SSL)
# SMTP_SECURE=false                       # true si usas puerto 465
# SMTP_USER=noreply@amcprincipal.com     # usuario SMTP
# SMTP_PASS=tu-contrasena-smtp           # contraseña SMTP
# SMTP_FROM=noreply@amcprincipal.com     # dirección remitente
